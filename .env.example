# @zenith/agent-core — variables de entorno
# Ninguna es obligatoria: cada proveedor se SALTA solo si su key no está configurada.
# El router intenta en orden y usa el primero disponible que responda.

# ── Proveedores LLM (router) ──
ANTHROPIC_API_KEY=        # Claude (primario en agentes conversacionales)
GEMINI_API_KEY=          # Gemini (fallback + embeddings de memoria semántica)
GROQ_API_KEY=            # Groq/Llama (fallback rápido y barato para extracción)
# Ollama no usa key: corre local en http://localhost:11434 (opcional, último eslabón gratis)

# ── Memoria Postgres (opcional, solo al escalar) ──
# Mientras uses FileStore NO se necesita. Activar con PostgresStore + schema.sql.
DATABASE_URL=            # ej. postgres://user:pass@host:5432/zenith
